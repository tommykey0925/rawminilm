                <mxCell id="f8" value="&lt;b&gt;確率 probs&lt;/b&gt;&lt;br&gt;shape: (9,)&lt;br&gt;全文字足すと 1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontColor=#121111;" parent="1" vertex="1">
