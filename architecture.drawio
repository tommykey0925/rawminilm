                <mxCell id="f6" value="&lt;b&gt;logits&lt;/b&gt;&lt;br&gt;shape: (9,)&lt;br&gt;各文字の&lt;br&gt;なりやすさスコア" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontColor=#121111;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="180" width="140" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="f7" value="&lt;b&gt;softmax&lt;/b&gt;&lt;br&gt;exp ÷ 合計&lt;br&gt;スコアを確率に変換" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontColor=#121111;" parent="1" vertex="1">
                    <mxGeometry x="1190" y="180" width="150" height="100" as="geometry"/>
