    <diagram id="training-loop" name="学習ループ">
        <mxGraphModel dx="800" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="1000" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <!-- タイトル -->
                <mxCell id="title2" value="&lt;font style=&quot;font-size:18px;&quot;&gt;&lt;b&gt;tiny.py 学習ループ&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1">
                    <mxGeometry x="270" y="20" width="260" height="40" as="geometry"/>
                </mxCell>
                <!-- Forward Pass -->
                <mxCell id="t1" value="&lt;b&gt;Forward Pass (順伝播)&lt;/b&gt;&lt;br&gt;入力文字 → Embedding → Linear → softmax&lt;br&gt;現在の重みで次の文字を予測する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
                    <mxGeometry x="220" y="90" width="360" height="80" as="geometry"/>
                </mxCell>
                <!-- Loss 計算 -->
                <mxCell id="t2" value="&lt;b&gt;Loss 計算 (CrossEntropy)&lt;/b&gt;&lt;br&gt;loss = -1/N × Σ log(正解文字の確率)&lt;br&gt;予測がどれだけハズレたかを1つの数値にする" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
                    <mxGeometry x="220" y="220" width="360" height="80" as="geometry"/>
                </mxCell>
                <!-- Backward Pass -->
                <mxCell id="t3" value="&lt;b&gt;Backward Pass (逆伝播)&lt;/b&gt;&lt;br&gt;dlogits → dW, db → dh → demb&lt;br&gt;loss を減らすには各重みをどう直すか計算する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
                    <mxGeometry x="220" y="350" width="360" height="80" as="geometry"/>
                </mxCell>
                <!-- SGD 更新 -->
                <mxCell id="t4" value="&lt;b&gt;SGD 更新&lt;/b&gt;&lt;br&gt;w = w - lr × dw&lt;br&gt;勾配の方向に重みを少しずつ動かす" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
                    <mxGeometry x="220" y="480" width="360" height="80" as="geometry"/>
                </mxCell>
                <!-- 判定 -->
                <mxCell id="t5" value="300ステップ&lt;br&gt;完了?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
                    <mxGeometry x="330" y="610" width="140" height="100" as="geometry"/>
                </mxCell>
                <!-- 生成フェーズ -->
                <mxCell id="t6" value="&lt;b&gt;生成フェーズ&lt;/b&gt;&lt;br&gt;学習済みの重みで&lt;br&gt;1文字ずつ予測を繰り返す" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
                    <mxGeometry x="310" y="770" width="180" height="80" as="geometry"/>
                </mxCell>
                <!-- 矢印: Forward → Loss -->
                <mxCell id="te1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="t1" target="t2" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- 矢印: Loss → Backward -->
                <mxCell id="te2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="t2" target="t3" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- 矢印: Backward → SGD -->
                <mxCell id="te3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="t3" target="t4" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- 矢印: SGD → 判定 -->
                <mxCell id="te4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="t4" target="t5" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- 矢印: 判定 → No (ループ) -->
                <mxCell id="te5" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#cc0000;fontColor=#cc0000;fontSize=13;fontStyle=1;" edge="1" source="t5" target="t1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="120" y="660"/>
                            <mxPoint x="120" y="130"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <!-- 矢印: 判定 → Yes (生成) -->
                <mxCell id="te6" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#009900;fontColor=#009900;fontSize=13;fontStyle=1;" edge="1" source="t5" target="t6" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>