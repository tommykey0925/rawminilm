                <mxCell id="f5" value="&lt;b&gt;Linear 層&lt;/b&gt;&lt;br&gt;dot(h, W) + b&lt;br&gt;W: (8×9), b: (9,)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontColor=#121111;" parent="1" vertex="1">
                    <mxGeometry x="790" y="180" width="160" height="100" as="geometry"/>
